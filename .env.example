# MongoDB Atlas connection string
# Get yours at: https://mongodb.com/atlas (free tier)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/spendwise?retryWrites=true&w=majority

# Resend API key
# Get yours at: https://resend.com (free tier - 100 emails/day)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT Secret - generate a random 64-character string
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
